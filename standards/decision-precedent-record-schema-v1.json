{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://projectlumina.org/memory/decision-precedent-record-schema-v1.json",
  "schema_version": "1.0.0",
  "last_updated": "2026-07-15",
  "title": "Decision Precedent Record Schema V1",
  "description": "A provider-neutral precedent describing a scoped decision and its observed outcome.",
  "type": "object",
  "additionalProperties": false,
  "required": ["record_type", "record_id", "organization_id", "site_id", "actor_id", "decision_summary", "outcome", "created_utc"],
  "properties": {
    "record_type": { "const": "DecisionPrecedentRecord" },
    "record_id": { "type": "string", "minLength": 1 },
    "organization_id": { "type": "string", "minLength": 1 },
    "site_id": { "type": "string", "minLength": 1 },
    "actor_id": { "type": "string", "minLength": 1 },
    "device_id": { "type": ["string", "null"], "minLength": 1 },
    "decision_summary": { "type": "string", "minLength": 1, "maxLength": 2048 },
    "outcome": { "type": "string", "enum": ["successful", "unsuccessful", "partial", "unknown"] },
    "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "domain_id": { "type": ["string", "null"] },
    "created_utc": { "type": "string", "format": "date-time" },
    "evidence_record_ids": { "type": "array", "items": { "type": "string" } },
    "external_system_reference": { "$ref": "#/$defs/external_system_reference" },
    "metadata": { "type": "object", "additionalProperties": true, "description": "Structured metadata without credentials, secrets, tokens, passwords, or raw transcripts." }
  },
  "$defs": {
    "external_system_reference": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["connector_instance_id", "external_record_type", "external_record_id"],
      "properties": {
        "connector_instance_id": { "type": "string", "minLength": 1 },
        "external_record_type": { "type": "string", "minLength": 1 },
        "external_record_id": { "type": "string", "minLength": 1 },
        "provider_data": { "type": "object", "additionalProperties": true, "description": "Namespaced provider details only; credentials are forbidden." }
      }
    }
  }
}
