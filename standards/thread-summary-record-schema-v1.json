{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://projectlumina.org/memory/thread-summary-record-schema-v1.json",
  "schema_version": "1.0.0",
  "last_updated": "2026-07-15",
  "title": "Thread Summary Record Schema V1",
  "description": "A concise, pseudonymous summary of a scoped operational thread without raw transcript persistence.",
  "type": "object",
  "additionalProperties": false,
  "required": ["record_type", "record_id", "organization_id", "site_id", "actor_id", "summary", "created_utc"],
  "properties": {
    "record_type": { "const": "ThreadSummaryRecord" },
    "record_id": { "type": "string", "minLength": 1 },
    "organization_id": { "type": "string", "minLength": 1 },
    "site_id": { "type": "string", "minLength": 1 },
    "actor_id": { "type": "string", "minLength": 1 },
    "device_id": { "type": ["string", "null"], "minLength": 1 },
    "thread_id": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1, "maxLength": 4096 },
    "topics": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "status": { "type": "string", "enum": ["open", "resolved", "escalated", "archived"] },
    "created_utc": { "type": "string", "format": "date-time" },
    "content_hash": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "external_system_reference": { "$ref": "#/$defs/external_system_reference" },
    "metadata": { "type": "object", "additionalProperties": true, "description": "Structured metadata without credentials, secrets, tokens, passwords, or raw transcripts." }
  },
  "$defs": {
    "external_system_reference": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["connector_instance_id", "external_record_type", "external_record_id"],
      "properties": {
        "connector_instance_id": { "type": "string", "minLength": 1 },
        "external_record_type": { "type": "string", "minLength": 1 },
        "external_record_id": { "type": "string", "minLength": 1 },
        "provider_data": { "type": "object", "additionalProperties": true, "description": "Namespaced provider details only; credentials are forbidden." }
      }
    }
  }
}
